# Copie para application-local.yml e preencha com SMTP da inbox Mailtrap (Email Testing)
spring:
  mail:
    host: sandbox.smtp.mailtrap.io
    port: 2525
    username: SEU_USERNAME_SMTP
    password: SUA_SENHA_SMTP
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true

app:
  mail:
    provider: mailtrap
